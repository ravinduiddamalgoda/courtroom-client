# ── SinLlama Courtroom Client Configuration ────────────────────────────────
# Copy this file and source it before running the app, or use a .env loader.

# URL of the diarization API server (running on Vast.ai or local)
DIARIZATION_API_URL=https://succeedable-andrea-overdependent.ngrok-free.dev

# API key (must match SINLLAMA_API_KEY on the server)
SINLLAMA_API_KEY=huruwa*xK9mN2pLq5vW8jY3hZ7bF6cD4eR1sT0uV

# Directory where sessions (JSON + WAV) are stored locally
SESSIONS_DIR=./sessions

# Path to Sinhala font files for PDF export (NotoSansSinhala recommended)
SINHALA_FONT_PATH=./fonts/NotoSansSinhala-Regular.ttf
SINHALA_FONT_BOLD=./fonts/NotoSansSinhala-Bold.ttf

# ── I2C LCD Display ───────────────────────────────────────────────────────────
# Set LCD_ENABLED=false to disable LCD output entirely
LCD_ENABLED=true

# I2C address of the LCD backpack (PCF8574 = 0x27, PCF8574A = 0x3F)
# Run `i2cdetect -y 1` on the Pi to confirm your address
LCD_I2C_ADDRESS=0x27

# LCD dimensions — common sizes: 16x2 or 20x4
LCD_COLS=20
LCD_ROWS=4
